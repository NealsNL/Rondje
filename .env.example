# Copy this file to ".env" if you want to change defaults. The app works
# without a .env file too — these are just the defaults.

# Base URL of the local BRouter routing server (used by the Next.js app).
BROUTER_URL=http://localhost:17777

# Port the BRouter server listens on (used by scripts/start-brouter.mjs).
BROUTER_PORT=17777
